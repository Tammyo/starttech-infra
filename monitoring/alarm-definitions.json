{
  "alarms": [
    {
      "name": "starttech-cpu-high",
      "description": "CPU utilization above 80%",
      "metric": "CPUUtilization",
      "namespace": "AWS/EC2",
      "threshold": 80,
      "comparison": "GreaterThanThreshold",
      "period": 120,
      "evaluation_periods": 2,
      "action": "scale-up"
    },
    {
      "name": "starttech-cpu-low",
      "description": "CPU utilization below 20%",
      "metric": "CPUUtilization",
      "namespace": "AWS/EC2",
      "threshold": 20,
      "comparison": "LessThanThreshold",
      "period": 120,
      "evaluation_periods": 2,
      "action": "scale-down"
    },
    {
      "name": "starttech-alb-5xx",
      "description": "ALB 5XX errors above 10",
      "metric": "HTTPCode_Target_5XX_Count",
      "namespace": "AWS/ApplicationELB",
      "threshold": 10,
      "comparison": "GreaterThanThreshold",
      "period": 60,
      "evaluation_periods": 2,
      "action": "notify"
    },
    {
      "name": "starttech-redis-cpu",
      "description": "Redis CPU above 75%",
      "metric": "CPUUtilization",
      "namespace": "AWS/ElastiCache",
      "threshold": 75,
      "comparison": "GreaterThanThreshold",
      "period": 300,
      "evaluation_periods": 2,
      "action": "notify"
    }
  ]
}
